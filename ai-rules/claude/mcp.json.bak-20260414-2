{
  "mcpServers": {
    "autodev-codebase": {
      "command": "pwsh",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "{{REPO_ROOT}}/scripts/autodev-codebase-current-git-mcp.ps1"
      ],
      "env": {
        "CODEBASE_WORKSPACE": "${CLAUDE_PROJECT_DIR}"
      }
    },
    "local-llm": {
      "command": "{{PYTHON_CMD}}",
      "args": ["{{REPO_ROOT}}/server_llm.py"]
    },
    "scopus-search": {
      "command": "{{PYTHON_CMD}}",
      "args": ["{{REPO_ROOT}}/server_scopus.py"]
    },
    "docx-manager": {
      "command": "{{PYTHON_CMD}}",
      "args": ["{{REPO_ROOT}}/server_docx.py"]
    },
    "pdf-indexer": {
      "command": "{{PYTHON_CMD}}",
      "args": ["{{REPO_ROOT}}/pdf-indexer-mcp/semantic_chunked_pdf_rag.py"]
    }
  }
}
