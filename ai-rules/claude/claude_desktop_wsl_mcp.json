{
  "mcpServers": {
    "autodev-codebase": {
      "command": "wsl",
      "args": ["bash", "-c", "~/.ai/bin/autodev-codebase-mcp.sh"],
      "env": {
        "CODEBASE_WORKSPACE": "${CLAUDE_PROJECT_DIR}"
      }
    },
    "local-llm": {
      "command": "wsl",
      "args": ["python3", "{{REPO_ROOT_WSL}}/server_llm.py"]
    },
    "scopus-search": {
      "command": "wsl",
      "args": ["python3", "{{REPO_ROOT_WSL}}/server_scopus.py"]
    },
    "docx-manager": {
      "command": "wsl",
      "args": ["python3", "{{REPO_ROOT_WSL}}/server_docx.py"]
    },
    "pdf-indexer": {
      "command": "wsl",
      "args": ["python3", "{{REPO_ROOT_WSL}}/pdf-indexer-mcp/semantic_chunked_pdf_rag.py"]
    }
  }
}
