{
  "mcpServers": {
    "autodev-codebase": {
      "command": "pwsh",
      "args": ["-NoLogo", "-NoProfile", "-File", "{{REPO_ROOT}}/scripts/autodev-codebase-current-git-mcp.ps1"],
      "env": {
        "CODEBASE_WORKSPACE": "${CLAUDE_PROJECT_DIR}"
      }
    },
    "local-llm": {
      "command": "wsl",
      "args": ["{{PYTHON_CMD_WSL}}", "{{REPO_ROOT_WSL}}/server_llm.py"]
    },
    "scopus-search": {
      "command": "wsl",
      "args": ["{{PYTHON_CMD_WSL}}", "{{REPO_ROOT_WSL}}/server_scopus.py"]
    },
    "docx-manager": {
      "command": "wsl",
      "args": ["{{PYTHON_CMD_WSL}}", "{{REPO_ROOT_WSL}}/server_docx.py"]
    },
    "pdf-indexer": {
      "command": "wsl",
      "args": ["{{PYTHON_CMD_WSL}}", "{{REPO_ROOT_WSL}}/pdf-indexer-mcp/semantic_chunked_pdf_rag.py"]
    }
  }
}
