# Template de configuracao MCP para o Codex.
# Este arquivo e uma fonte de referencia para bootstrap manual-assistido.
# Substitua os placeholders diretamente ao copiar ou mesclar para ~/.codex/config.toml.

[mcp_servers.autodev-codebase]
command = "{{AUTODEV_CMD}}"
args = {{AUTODEV_ARGS}}
startup_timeout_sec = 30

[mcp_servers.local-llm]
command = "{{PYTHON_CMD}}"
args = ["{{REPO_ROOT}}/server_llm.py"]
startup_timeout_sec = 20

[mcp_servers.local-llm.tools.generate]
approval_mode = "approve"

[mcp_servers.scopus-search]
command = "{{PYTHON_CMD}}"
args = ["{{REPO_ROOT}}/server_scopus.py"]
startup_timeout_sec = 30

[mcp_servers.scopus-search.env]
CHROMA_DIR = "{{CHROMA_DIR}}"

[mcp_servers.scopus-search.tools.collection_stats]
approval_mode = "approve"

[mcp_servers.docx-manager]
command = "{{PYTHON_CMD}}"
args = ["{{REPO_ROOT}}/server_docx.py"]
startup_timeout_sec = 20

[mcp_servers.docx-manager.tools.list_comments]
approval_mode = "approve"

[mcp_servers.docx-manager.tools.find_citar_paragraphs]
approval_mode = "approve"

[mcp_servers.docx-manager.tools.list_paragraphs]
approval_mode = "approve"

[mcp_servers.docx-manager.tools.insert_citation]
approval_mode = "approve"

[mcp_servers.docx-manager.tools.insert_candidate_comment]
approval_mode = "approve"
